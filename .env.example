# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- MySQL (Compose) ---
# Dung MYSQL_APP_USER / MYSQL_APP_PASSWORD (khong dung DB_USER o day): tren Windows bien he thong
# DB_USER=root co the ghi de .env va lam MYSQL_USER=root -> loi container MySQL.
MYSQL_APP_USER=finance_user
MYSQL_APP_PASSWORD=finance_password
MYSQL_ROOT_PASSWORD=root_password
DB_HOST=mysql
DB_PORT=3306
MYSQL_PUBLISH_PORT=3306
AUTH_DB_NAME=auth_user_db
FINANCE_DB_NAME=finance_db
REPORT_DB_NAME=report_db

# --- Service Ports ---
SERVICE_AUTH_USER_PORT=15001
SERVICE_TRANSACTION_BUDGET_PORT=15002
SERVICE_REPORT_NOTIFICATION_PORT=15003
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- API Gateway ---
PROXY_TIMEOUT_MS=8000
AUTH_USER_SERVICE_URL=http://service-auth-user:5000
TRANSACTION_BUDGET_SERVICE_URL=http://service-transaction-budget:5000
REPORT_NOTIFICATION_SERVICE_URL=http://service-report-notification:5000

# --- Security / Service runtime ---
JWT_SECRET=my-super-secret-key-123
JWT_EXPIRES_IN=1d
USE_MOCK_ADAPTER=false
